# ===========================
# Django Settings
# ===========================

# ВАЖНО: Сгенерируйте новый SECRET_KEY командой:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-min-50-characters

# Режим отладки (ВСЕГДА False в продакшене!)
DEBUG=False

# Разрешенные домены (через запятую без пробелов)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com


# ===========================
# Database (PostgreSQL)
# ===========================

# Оставьте пустым для использования SQLite в разработке
DB_NAME=barpro_production
DB_USER=barpro_user
DB_PASSWORD=strong_database_password_here
DB_HOST=localhost
DB_PORT=5432


# ===========================
# Email (опционально)
# ===========================

# Для отправки уведомлений о заявках
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@yourdomain.com


# ===========================
# Для разработки
# ===========================

# Раскомментируйте для локальной разработки:
# DEBUG=True
# SECRET_KEY=dev-secret-key-not-for-production
# ALLOWED_HOSTS=localhost,127.0.0.1
